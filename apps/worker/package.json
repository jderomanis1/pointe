{
  "name": "@pointe/worker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:e2e": "wrangler dev -c wrangler.dev.toml --port 8787 --ip 127.0.0.1 --local",
    "deploy": "wrangler deploy",
    "build:dryrun": "wrangler deploy --dry-run --outdir=.dist-prod",
    "typecheck": "tsc --noEmit",
    "test": "vitest run -c vitest.config.ts && vitest run -c vitest.workers.config.ts",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.12",
    "@cloudflare/workers-types": "^4.20260603.1",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "vitest": "^4.1.7",
    "wrangler": "^4.95.0"
  },
  "dependencies": {
    "@pointe/shared": "workspace:*"
  }
}
